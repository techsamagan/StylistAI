# ── Database ────────────────────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./style.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/asanur

# ── Selfie / image storage ───────────────────────────────────────────────────
# Leave S3_BUCKET unset to use local-filesystem storage (uploads/ served at
# /uploads). Set it to switch the color-analysis selfie storage to AWS S3 —
# credentials resolve from the standard AWS chain (env vars, ~/.aws, or IAM role).
# S3_BUCKET=asanur-uploads
# AWS_REGION=us-east-1
# S3_URL_TTL_SECONDS=3600          # presigned GET URL lifetime
# AWS_ACCESS_KEY_ID=...            # optional — omit when using an IAM role / profile
# AWS_SECRET_ACCESS_KEY=...

# ── Virtual try-on (existing shopping feature) ───────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Access control ───────────────────────────────────────────────────────────
# CORS: comma-separated frontend origin(s). Set to your deployed frontend URL.
# ALLOWED_ORIGINS=https://app.asanur.com
#
# Optional IP allowlist. Leave UNSET for normal production (no IP restriction).
# Set it only to lock the API to specific machines (e.g. a private LAN deploy):
# ALLOWED_IPS=127.0.0.1,::1,10.0.0.32
